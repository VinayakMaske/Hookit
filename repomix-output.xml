                  <PlusCircle className="w-5 h-5" />
                  Create Hook
                </Button>
              </Link>
            </div>
          </div>
        )}
      </nav>

      {/* Edit Profile Modal */}
      {showEditModal && <EditProfileModal onClose={() => setShowEditModal(false)} />}
    </>
  )
}
