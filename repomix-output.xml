                                    </Button>
                                </a>
                            ) : isSoldOut ? (
                                <Button 
                                    size="lg" 
                                    className="w-full h-14 text-lg gap-2 bg-neutral-300 hover:bg-neutral-300 cursor-not-allowed" 
                                    disabled
                                >
                                    <ShoppingBag className="w-5 h-5" />
