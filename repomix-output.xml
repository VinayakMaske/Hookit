import {
    LayoutDashboard,
    ShoppingCart,
    Wallet,
    Users,
    Store,
    ArrowLeft,
    LogOut
} from 'lucide-react'

const ADMIN_EMAILS = ['your-email@example.com'] // Same as middleware

export default async function AdminLayout({ children }: { children: React.ReactNode }) {
    const supabase = await createClient()
