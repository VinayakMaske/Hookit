    if (!user || !ADMIN_EMAILS.includes(user.email || '')) {
        redirect('/')
    }

    const navItems = [
        { href: '/admin', label: 'Dashboard', icon: LayoutDashboard },
        { href: '/admin/orders', label: 'All Orders', icon: ShoppingCart },
        { href: '/admin/payouts', label: 'Payouts', icon: Wallet },
