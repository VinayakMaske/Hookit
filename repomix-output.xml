                                    <span className="text-neutral-600">Payout Day</span>
                                </div>
                                <div className="flex items-center gap-2">
                                    <div className="w-3 h-3 rounded-full bg-red-400" />
                                    <span className="text-neutral-600">Bank Holiday</span>
                                </div>
