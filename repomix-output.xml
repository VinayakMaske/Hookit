              {hookType === 'blog' && <FileText className="w-3 h-3" />}
              {hookType === 'product' && <ShoppingBagIcon className="w-3 h-3" />}
              {HOOK_TYPE_CONFIG[hookType]?.label}
            </span>
          </div>
        </div>
      </div>
    </div>
  )
}

