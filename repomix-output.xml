                                        <h3 className="font-semibold text-neutral-900">{item.title}</h3>
                                        <Badge variant="secondary" className="text-xs">{item.badge}</Badge>
                                    </div>
                                    <p className="text-sm text-neutral-600">{item.description}</p>
