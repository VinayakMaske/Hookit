                ifsc_code: formData.ifscCode,
                bank_name: formData.bankName,
                email: formData.email,
                phone: formData.phone
            }, { onConflict: 'seller_id' })

        if (upsertError) {
            setError(upsertError.message)
            setSaving(false)
            return
        }

        setSuccess(true)
        setSaving(false)
