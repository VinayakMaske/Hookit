                                        </p>
                                    </div>
                                    <Link href={`/store/${product.stores?.slug}`}>
                                        <Button variant="outline" size="sm">
                                            Visit Store
                                        </Button>
                                    </Link>
                                </div>
                            </CardContent>
                        </Card>
                    </div>
                </div>

                {/* Related Products */}
