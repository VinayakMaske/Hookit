                                        'bg-blue-100 text-blue-700'
                                    )}>
                                        {order.status}
                                    </span>
                                </div>
                            ))}
                        </div>
                    ) : (
                        <p className="text-neutral-500 text-center py-8">No orders yet</p>
                    )}
                </CardContent>
            </Card>
        </div>
    )
}

function cn(...classes: (string | undefined | false)[]) {
    return classes.filter(Boolean).join(' ')
}
