                        >
                            {product.stores?.logo_url ? (
                                <img
                                    src={product.stores.logo_url}
                                    alt={product.stores.name}
                                    className="w-6 h-6 rounded-full object-cover"
                                />
                            ) : (
                                <Store className="w-5 h-5 text-neutral-500" />
