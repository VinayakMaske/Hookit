                                    const isHoliday = [15, 16].includes(day) // Example holidays
                                    const hasDelivery = [2, 5, 9, 12, 16, 19, 23, 26, 30].includes(day)
                                    const hasPayout = [4, 7, 11, 14, 18, 21, 25, 28].includes(day)
                                    
                                    return (
