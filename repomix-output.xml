                                                    {order.buyer_phone && (
                                                        <p className="text-sm text-neutral-600 flex items-center gap-1">
                                                            <Phone className="w-3 h-3" /> {order.buyer_phone}
                                                        </p>
                                                    )}
                                                    {order.buyer_email && (
