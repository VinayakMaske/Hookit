                            <p className="text-xs text-neutral-500">
                                PNG, JPG or WebP. Max 5MB each. You can select multiple images at once.
                            </p>
                        </div>

                        <div className="border-t border-neutral-200" />

                        {/* ===== AFFILIATE & ACTIVE ===== */}
                        <div className="space-y-4">
